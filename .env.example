# Lumina Frontend environment variables
# Copy this file to .env.local and adjust values for your environment.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Never place secrets behind the NEXT_PUBLIC_ prefix.

# Base URL of the Lumina backend API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Soroban RPC endpoint for contract reads and transaction submission.
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Active Stellar network: testnet | futurenet | mainnet
NEXT_PUBLIC_NETWORK=testnet

# Sentry DSN for client-side error reporting. Leave empty to disable.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry org and project for source map uploads (required for production builds).
SENTRY_ORG=
SENTRY_PROJECT=

# WalletConnect project ID for wallet sessions. Leave empty to disable.
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
